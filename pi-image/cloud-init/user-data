#cloud-config
package_update: true
package_upgrade: false
packages:
  - ca-certificates
  - curl
  - ffmpeg
  - git
  - jq
  - python3
  - python3-pip
  - python3-venv
  - tmux
  - unzip
  - xz-utils
  - docker.io
  - docker-compose-v2

runcmd:
  - mkdir -p /var/lib/yaver
  - chmod 0755 /var/lib/yaver
  - systemctl daemon-reload
  - systemctl enable yaver-pi-firstboot.service
  - systemctl start yaver-pi-firstboot.service
