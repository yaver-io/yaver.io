<?xml version="1.0" encoding="utf-8"?>
<!--
  Yaver Connector Box — Android USB-host device filter.

  Drop into the Yaver mobile app at:
      mobile/android/app/src/main/res/xml/usb_device_filter.xml
  and reference it from AndroidManifest.xml on the activity that owns the
  USB-serial link:

      <activity ... android:directBootAware="true">
        <intent-filter>
          <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
        </intent-filter>
        <meta-data
          android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
          android:resource="@xml/usb_device_filter" />
      </activity>

  When the phone is plugged into the box (WIRED mode), Android raises the
  attach intent and shows the one-time permission dialog with "use by default
  for this device" — tick once and reconnect/reboot never re-prompts
  (directBootAware keeps the app alive to restore the grant).

  Covers the box's onboard USB-serial bridges (ESP32-S3 native CDC + FT232) AND
  the common chipsets a 3D printer / machine USB presents through the box's
  USB-A passthrough, so the same filter claims the printer too. Reliability
  ranking on Android: FTDI > CP210x > CH340 > PL2303.
-->
<resources>
  <!-- Espressif ESP32-S3 native USB CDC (the facade bridge) -->
  <usb-device vendor-id="12346" product-id="4097" />   <!-- 0x303A / 0x1001 -->
  <usb-device vendor-id="12346" />                       <!-- 0x303A any Espressif CDC -->

  <!-- FTDI (onboard FT232 raw path + many printers/controllers) -->
  <usb-device vendor-id="1027" product-id="24577" />    <!-- 0x0403 / 0x6001 FT232R -->
  <usb-device vendor-id="1027" product-id="24592" />    <!-- 0x0403 / 0x6010 FT2232 -->
  <usb-device vendor-id="1027" product-id="24593" />    <!-- 0x0403 / 0x6011 FT4232 -->
  <usb-device vendor-id="1027" product-id="24596" />    <!-- 0x0403 / 0x6014 FT232H -->
  <usb-device vendor-id="1027" product-id="24577" />    <!-- duplicate-safe -->

  <!-- Silicon Labs CP210x -->
  <usb-device vendor-id="4292" product-id="60000" />    <!-- 0x10C4 / 0xEA60 CP2102 -->
  <usb-device vendor-id="4292" product-id="60016" />    <!-- 0x10C4 / 0xEA70 CP2105 -->

  <!-- WCH CH340 / CH341 (cheap printers/controllers) -->
  <usb-device vendor-id="6790" product-id="21795" />    <!-- 0x1A86 / 0x5523 CH341 -->
  <usb-device vendor-id="6790" product-id="29987" />    <!-- 0x1A86 / 0x7523 CH340 -->
  <usb-device vendor-id="6790" product-id="21972" />    <!-- 0x1A86 / 0x55D4 CH9102 -->

  <!-- Prolific PL2303 -->
  <usb-device vendor-id="1659" product-id="8963" />     <!-- 0x067B / 0x2303 -->
</resources>
