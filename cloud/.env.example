# Copy to cloud/.env on the Hetzner box. Never commit the populated file.

# Public hostname — DNS A record must already point here.
CLOUD_DOMAIN=cloud.yaver.io

# Let's Encrypt renewal contact.
CLOUD_TLS_EMAIL=admin@yaver.io

# Long-lived bearer token the agent accepts as "owner". Generate once:
#   openssl rand -hex 32
# and store it in the team vault. Clients (mobile, CLI) use this to auth
# against /phone/projects/receive until per-user tokens land.
CLOUD_OWNER_TOKEN=

# Owner user id recorded on deployments for audit purposes.
CLOUD_OWNER_USER_ID=cloud-owner
