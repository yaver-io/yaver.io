# Yaver Cloud — the "yaver image" a bought managed box runs.
#
# A managed-cloud purchase provisions a cpx42 VM whose only job is:
#   install Docker → `docker run ghcr.io/kivanccakmak/yaver-cloud`
# with a per-user config volume mounted. The container IS the box:
# the Yaver Go agent plus every tool a RN/Expo + web + deploy dev
# loop needs, so cold provisions are fast and the env is identical
# everywhere. For multi-tenant (Phase 2) the container is also the
# per-tenant boundary — but plain Docker is NOT a strong boundary
# for untrusted tenants; that phase swaps the runtime to Kata /
# Firecracker (see backend task: secure multi-tenant runtime). For
# single-user (one buyer, one dedicated VM) this image is sufficient.
#
# Build:  docker build -f Dockerfile.yaver-cloud \
#           -t ghcr.io/kivanccakmak/yaver-cloud:latest .
# Run  :  docker run -d --name yaver -p 18080:18080 \
#           -v yaver-home:/root ghcr.io/kivanccakmak/yaver-cloud:latest
#
# The /root volume persists ~/.yaver, ~/.claude, ~/.codex,
# ~/.config/opencode, ~/.config/gh, ~/.config/glab — so the agent's
# remote-OAuth sync (yaver + claude-code + codex + opencode) and the
# GLM api-key setting survive container restarts / image upgrades.

# ── Stage 1: build the Yaver Go agent FROM SOURCE ────────────────────
# The image build context is desktop/agent (see
# .github/workflows/build-yaver-cloud-image.yml) — i.e. the agent
# source + go.mod. Building from source (not fetching a release
# tarball) means every image — and therefore every provisioned box —
# runs the EXACT agent on this commit, including new ops verbs
# (e.g. runner_auth) without waiting on a cli/v* release. Also
# permanently removes the brittle "raw asset vs .tar.gz" fetch class.
#
# Build context (per build-yaver-cloud-image.yml) is the REPO ROOT — we
# build TWO Go binaries from two separate modules:
#   * yaver       (desktop/agent/) — the agent
#   * yaver-relay (relay/)         — the per-user managed relay (Phase 2);
#                                    same binary the public yaver-relay
#                                    image ships, bundled in-process so a
#                                    managed box is ONE container, not
#                                    two. Both share the box's volume +
#                                    network namespace; supervised by a
#                                    tiny entrypoint wrapper (no
#                                    supervisord — the relay is best-
#                                    effort, the agent is mission-critical
#                                    and gets `exec`'d as PID 1).
FROM golang:1.26-bookworm AS agentbuild
WORKDIR /src
COPY desktop/agent/go.mod desktop/agent/go.sum ./
RUN go mod download
COPY desktop/agent/ .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/yaver .

FROM golang:1.22-bookworm AS relaybuild
WORKDIR /src
COPY relay/go.mod relay/go.sum ./
RUN go mod download
COPY relay/ .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/yaver-relay .

# ── Stage 2: runtime ─────────────────────────────────────────────────
FROM node:22-bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/usr/local/go/bin:/root/go/bin:/root/.cargo/bin:/usr/local/bin:${PATH}"
ENV HOME=/root

# ── System packages ──────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl wget ca-certificates gnupg2 openssh-client \
      build-essential cmake pkg-config \
      python3 python3-pip python3-venv \
      zip unzip jq tree ripgrep tmux file \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI (gh) ──────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# ── GitLab CLI (glab) ────────────────────────────────────────────────
RUN ARCH=$(dpkg --print-architecture) \
    && GLAB_VER=$(curl -fsSL https://gitlab.com/api/v4/projects/gitlab-org%2Fcli/releases | \
         python3 -c "import sys,json;print(json.load(sys.stdin)[0]['tag_name'].lstrip('v'))") \
    && curl -fsSL "https://gitlab.com/gitlab-org/cli/-/releases/v${GLAB_VER}/downloads/glab_${GLAB_VER}_linux_${ARCH}.deb" \
         -o /tmp/glab.deb \
    && apt-get update && apt-get install -y /tmp/glab.deb && rm -f /tmp/glab.deb \
    && rm -rf /var/lib/apt/lists/*

# ── Go ───────────────────────────────────────────────────────────────
ARG GO_VERSION=1.22.6
RUN ARCH=$(dpkg --print-architecture) \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${ARCH}.tar.gz" | tar -C /usr/local -xz

# ── Rust ─────────────────────────────────────────────────────────────
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
      | sh -s -- -y --default-toolchain stable --profile minimal

# ── RN / Expo / Hermes bundling + deploy tooling ─────────────────────
# hermesc ships per-project inside react-native; the toolchain needs
# Node (above) + expo/eas + a global RN CLI for `yaver` /dev/build-native.
RUN npm install -g expo-cli eas-cli @react-native-community/cli wrangler 2>/dev/null || true

# ── Coding runners (subscription-OAuth at runtime, never API-key) ────
# OAuth tokens are NOT baked in — they arrive via the mounted /root
# volume + yaver's remote-auth sync. GLM api-key is an opencode setting
# written to ~/.config/opencode at runtime, also on the volume.
RUN npm install -g \
      @anthropic-ai/claude-code@latest \
      @openai/codex@latest \
      opencode-ai@latest 2>/dev/null || true

# ── Yaver Go agent (built from source in stage 1) ────────────────────
# Deterministic per image: this is the agent on the building commit,
# so provisioned boxes get new ops verbs (runner_auth, …) immediately
# on the next image build — no cli/v* release dependency.
COPY --from=agentbuild /out/yaver /usr/local/bin/yaver
RUN chmod +x /usr/local/bin/yaver && /usr/local/bin/yaver --version >/dev/null 2>&1

# ── Yaver Relay (Phase 2 — managed box doubles as user's relay) ──────
# Bundled inside this same image so a managed box is ONE container, not
# two: the entrypoint wrapper backgrounds `yaver-relay serve` when
# RELAY_PASSWORD is set, then `exec yaver "$@"` so the agent stays PID 1
# (HEALTHCHECK + docker stop signals still target the agent). When
# RELAY_PASSWORD is unset (BYO / no managed sub) the relay simply isn't
# started — same as before. The relay's QUIC port is 4433/UDP and admin
# /health is 8443/TCP (relay/Dockerfile; relay/main.go:71).
COPY --from=relaybuild /out/yaver-relay /usr/local/bin/yaver-relay
RUN chmod +x /usr/local/bin/yaver-relay && /usr/local/bin/yaver-relay --help >/dev/null 2>&1 || true
COPY <<'ENTRYPOINT_SH' /usr/local/bin/yaver-cloud-entrypoint.sh
#!/bin/sh
# Phase 2 supervisor — best-effort relay, mission-critical agent.
# RELAY_PASSWORD is threaded from cloud-init `docker run -e ...` only on
# managed boxes that have a subscription (cloudMachines.provision).
# Unset ⇒ relay stays off; the agent still serves normally.
if [ -n "${RELAY_PASSWORD:-}" ]; then
  # CONVEX_URL is passed from cloud-init when set so the relay can
  # per-user-validate incoming tunnel registrations against the
  # caller's managedRelays.password hash (relay/main.go --convex-url;
  # the platform relay always runs in this mode). Password-only mode
  # is fine for a single-owner box, but with --convex-url an attacker
  # who steals the relay password still can't tunnel as a different
  # user's identity. Empty CONVEX_URL ⇒ password-only fallback (no
  # behaviour change vs ungated relay).
  yaver-relay serve --quic-port=4433 --http-port=8443 \
    ${CONVEX_URL:+--convex-url="$CONVEX_URL"} \
    >/var/log/yaver-relay.log 2>&1 &
fi
exec yaver "$@"
ENTRYPOINT_SH
RUN chmod +x /usr/local/bin/yaver-cloud-entrypoint.sh

# Persisted dirs (remote-OAuth + caches) — mounted as a Docker volume
# so claude/codex/opencode/gh/glab/yaver auth + GLM api-key survive
# restarts and image upgrades.
RUN mkdir -p /root/.yaver /root/.claude /root/.codex \
      /root/.config/opencode /root/.config/gh /root/.config/glab \
      /root/.npm /root/.cargo/registry /root/go/pkg/mod \
      /srv/yaver/workspace

WORKDIR /srv/yaver/workspace

EXPOSE 18080 4433/udp 8443

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
  CMD curl -fsS http://127.0.0.1:18080/health >/dev/null || exit 1

# The agent reads /root/.yaver/config.json (auth_token,
# convex_site_url, device_id) written by the VM cloud-init into the
# mounted volume, then registers as the buyer's device and serves the
# dev-server / Hermes / ops API on 18080. The entrypoint wrapper
# additionally backgrounds yaver-relay when RELAY_PASSWORD is set
# (managed-cloud Phase 2); unset ⇒ behaviour identical to pre-Phase-2.
ENTRYPOINT ["/usr/local/bin/yaver-cloud-entrypoint.sh"]
CMD ["serve", "--debug", "--port", "18080"]
