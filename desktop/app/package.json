{
  "name": "Yaver.io",
  "version": "1.0.0",
  "description": "Yaver Desktop — Vibe coding with AI, connected to your dev machine",
  "author": {
    "name": "Yaver",
    "email": "kivanc@yaver.io"
  },
  "homepage": "https://yaver.io",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "io.yaver.desktop",
    "productName": "Yaver",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Development",
      "icon": "assets/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
