# Auto-generated platform shells (generated by `flutter create .`).
# Two overlays are force-tracked (`git add -f`) because they carry the
# Yaver-friendly launcher labels ("Todo Flutter") that the Go agent's
# parseAppName reads to populate the Hot Reload list. After
# `flutter create .` regenerates these files locally, restore the
# overlays with:
#   git checkout -- \
#     demo/mobile/todo-flutter/android/app/src/main/AndroidManifest.xml \
#     demo/mobile/todo-flutter/ios/Runner/Info.plist
android/
ios/
linux/
macos/
windows/
web/
