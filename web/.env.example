# Convex Backend URL
CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# Base URL for this website
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# OAuth Providers (get from respective developer consoles)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT_ID=

# Apple Sign-In (get from Apple Developer Console)
OAUTH_APPLE_CLIENT_ID=your.apple.services.id
OAUTH_APPLE_CLIENT_SECRET=

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

OAUTH_GITLAB_CLIENT_ID=
OAUTH_GITLAB_CLIENT_SECRET=
