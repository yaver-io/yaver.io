{
  "name": "yaver-feedback-web",
  "version": "0.2.5",
  "description": "Visual feedback SDK for web apps \u2014 screen recording, voice annotations, and local-first developer workflows through Yaver",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kivanccakmak/yaver.io",
    "directory": "sdk/feedback/web"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "jest --runInBand",
    "test:ci": "npm run build && npm test"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "keywords": [
    "yaver",
    "feedback",
    "bug-report",
    "screen-recording",
    "web",
    "developer-runtime",
    "local-first"
  ],
  "files": [
    "dist/",
    "src/",
    "tsconfig.json"
  ]
}
