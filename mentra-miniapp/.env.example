# MentraOS miniapp credentials — get these from https://console.mentra.glass
# after registering the io.yaver.agent package.
MENTRAOS_PACKAGE_NAME=io.yaver.agent
MENTRAOS_API_KEY=

# Where to reach the local Yaver agent. Default: same-host on the canonical
# agent port. Override when running the miniapp on a different machine
# from the agent (e.g. miniapp on a VPS, agent on user's MacBook reachable
# via Tailscale: http://primary.tail-abc.ts.net:18080).
YAVER_AGENT_URL=http://127.0.0.1:18080

# Bearer token for the agent's authSDK gate. Mint via `yaver sdk token`
# with scope feedback,voice (or omit scope for all SDK surfaces).
YAVER_SDK_TOKEN=

# Default project slug for transcription bias + task workDir. Empty =
# whatever the agent's Voice.DefaultProject is.
YAVER_PROJECT=

# Listen port for the MentraOS cloud to connect to this miniapp. 80 by
# default; if you bind on a non-privileged port use 8080 + a tunnel
# (Mentra cloud must reach this URL).
PORT=8080
