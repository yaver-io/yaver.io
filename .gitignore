sdk/go/clib/libyaver.*

# Generated SDK configs — carry a live auth token + absolute local path; never commit.
# Regenerated locally by `yaver` tooling; safe to be absent for anyone who clones.
**/yaver-sdk/config.generated.json
**/config.generated.json

# Android on-device sandbox payload — built at deploy time by
# scripts/build-android-sandbox.sh, never committed (the Go agent is ~45 MB and
# proot binaries are fetched/pinned). SandboxService loads them from jniLibs.
mobile/android/app/src/main/jniLibs/*/libyaver.so
mobile/android/app/src/main/jniLibs/*/libproot.so
mobile/android/app/src/main/jniLibs/*/libproot-loader.so
mobile/android/app/src/main/jniLibs/.sandbox-payload.txt
sdk/python/__pycache__/
__pycache__/
desktop/agent/.yaver/
sdk/js/dist/
sdk/js/node_modules/
sdk/js/.npmrc
sdk/**/*.tgz
relay/relay
mcp/mcp
mcp/yaver-mcp
videos/

# CI runtime artifacts (server-ip, server-id, logs from remote-verify)
ci/.artifacts/
.claude/
IstanbulDigerK4.pdf
desktop/agent/agent.exe

# Local penetration-testing suite (offensive tooling — keep out of public repo)
security/pentest/

# Security working docs — attack-surface catalogs / fix trackers. Never commit
# to the public repo (they enumerate live/unfixed surface). Post-fix public
# write-ups go in docs/ deliberately, not these.
/SECURITY_AUDIT_BRIEF.md
/SECURITY_FIX_PROGRESS.md
/SECURITY_AUDIT_FINDINGS.md
/docs/security-audit-2026-07-13.md
/docs/security/security_audit.md

# readme-beautify skill install (npx skills add) — tooling, not product
.agents/skills/
skills-lock.json
